  "main": "index.html",
  "scripts": {
    "gulp": "gulp",
    "build": "gulp build",
    "dev": "gulp",
    "lint": "npm run lint:js && npm run lint:styles && npm run format:check",
    "lint:js": "eslint gulpfile.js postcss.config.js tailwind.config.js app/js/**/*.js",
    "lint:styles": "stylelint \"app/css/**/*.css\"",
    "format": "prettier \"app/**/*.{js,css}\" \"*.{js,json,md,cjs}\" --write",
    "format:check": "prettier \"app/**/*.{js,css}\" \"*.{js,json,md,cjs}\" --check",
    "validate:html": "html-validate \"dist/**/*.html\"",
    "fonts:download": "node scripts/download-fonts.js",
    "a11y": "node scripts/a11y.js",
    "qa": "npm run build && npm run lint && npm run validate:html && npm run a11y",
    "check:cursor-mirror": "node scripts/check-cursor-mirror.js"
  },
  "author": "droog",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.1",
